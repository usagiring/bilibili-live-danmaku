{
  "name": "bilibili-danmaku",
  "version": "0.5.9",
  "author": "其妙 <hling51325@163.com>",
  "description": "这是一个哔哩哔哩的直播弹幕应用",
  "license": "MIT",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "node .electron-vue/build.js && electron-builder",
    "build:all": "npm run build:danmaku && npm run build:danmaku-scroll && node .electron-vue/build.js && electron-builder",
    "build:dir": "node .electron-vue/build.js && electron-builder --dir",
    "build:clean": "cross-env BUILD_TARGET=clean node .electron-vue/build.js",
    "build:web": "cross-env BUILD_TARGET=web node .electron-vue/build.js",
    "dev": "node .electron-vue/dev-runner.js",
    "pack": "npm run pack:main && npm run pack:renderer",
    "pack:main": "cross-env NODE_ENV=production webpack --progress --colors --config .electron-vue/webpack.main.config.js",
    "pack:renderer": "cross-env NODE_ENV=production webpack --progress --colors --config .electron-vue/webpack.renderer.config.js",
    "postinstall": "",
    "ui": "vue ui",
    "release": "npm run build -- -p always",
    "cnpmi": "npm --registry https://registry.npm.taobao.org install",
    "build:danmaku": "cd danmaku && npm run build:monorepo",
    "build:danmaku-scroll": "cd danmaku-scroll && npm run build:monorepo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/usagiring/bilibili-live-danmaku.git"
  },
  "build": {
    "productName": "bilibili-danmaku",
    "appId": "com.electron.bilibili-danmaku",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/electron/**/*"
    ],
    "extraFiles": [
      "config.yaml"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "koa"
    ]
  },
  "overrides": {
    "webpack": "5.74.0"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@tokine/bilibili-bridge": "0.2.24",
    "axios": "^1.16.1",
    "echarts": "^6.1.0",
    "echarts-wordcloud": "^2.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "flv.js": "^1.6.2",
    "follow-redirects": "^1.16.0",
    "font-list": "^2.1.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "qrcode": "^1.5.4",
    "view-ui-plus": "^1.3.24",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vue3-smooth-dnd": "^0.0.6",
    "vuex": "^4.1.0",
    "vuex-electron": "github:usagiring/vuex-electron",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-export-default-from": "^7.27.1",
    "@babel/plugin-transform-export-namespace-from": "^7.29.7",
    "@babel/plugin-proposal-function-bind": "^7.27.1",
    "@babel/plugin-transform-json-strings": "^7.29.7",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.29.7",
    "@babel/plugin-transform-optional-chaining": "^7.29.7",
    "@babel/plugin-proposal-throw-expressions": "^7.27.1",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.29.3",
    "@babel/runtime": "^7.29.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "babel-loader": "^10.1.1",
    "cfonts": "^3.3.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "del": "^8.0.1",
    "@electron/devtron": "^2.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-debug": "^4.1.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "multispinner": "^0.2.1",
    "node-loader": "^2.1.0",
    "prettier": "^3.8.3",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.0",
    "typescript": "^6.0.3",
    "url-loader": "^4.1.1",
    "vue-html-loader": "^1.2.4",
    "vue-loader": "^17.4.2",
    "vue-style-loader": "^4.1.3",
    "vue-template-compiler": "^2.7.16",
    "vue-tsc": "^3.3.1",
    "webpack": "5.107.1",
    "webpack-dev-server": "^5.2.4",
    "webpack-hot-middleware": "^2.26.1",
    "worklet-loader": "^2.0.0"
  }
}
